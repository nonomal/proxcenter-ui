generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// Modèles gérés par Prisma
// Les autres tables (users, sessions, RBAC, audit_logs, etc.)
// sont créées et gérées par sqlite.ts
// ============================================

model Connection {
  id               String  @id @default(cuid())
  tenantId         String  @default("default") @map("tenant_id")
  name             String
  type             String  @default("pve")
  subType          String? @map("sub_type")
  vmwareDatacenter String? @map("vmware_datacenter")
  hypervShareName  String? @map("hyperv_share_name")
  baseUrl          String
  behindProxy      Boolean @default(false)
  insecureTLS      Boolean @default(false)
  hasCeph          Boolean @default(false)
  latitude         Float?
  longitude        Float?
  locationLabel    String?
  country          String? // ISO-3166-1 alpha-2 (e.g. "FR", "DE"). Optional, set in /settings?tab=connections.
  apiTokenEnc      String
  fingerprint      String? // SHA256 cert fingerprint; populated for PBS connections
  // v1.5: connection access profile, enforced at the HTTP-client boundary in
  // a later step. Defaults to today's behavior (full_admin) so existing
  // connections are unchanged.
  accessProfile String @default("full_admin") @map("access_profile")

  // Custom ProxCenter tags (semicolon-separated)
  tags String?

  // SSH fields
  sshEnabled    Boolean @default(false)
  sshPort       Int     @default(22)
  sshUser       String  @default("root")
  sshAuthMethod String?
  sshKeyEnc     String?
  sshPassEnc    String?
  sshUseSudo    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hosts ManagedHost[]

  // Back-references for the green-IT datacentre overrides. Required by
  // Prisma's relation declaration on ConnectionGreenConfig / NodeGreenConfig
  // — they let the FKs exist without needing to be queried from this side.
  greenConfig     ConnectionGreenConfig?
  nodeGreenConfig NodeGreenConfig[]

  providerConnection ProviderConnection?
  licenseMapping     LicenseMapping?
}

model ManagedHost {
  id           String      @id @default(cuid())
  tenantId     String      @default("default") @map("tenant_id")
  connectionId String?
  connection   Connection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  node         String
  ip           String?
  sshAddress   String?
  displayName  String?
  enabled      Boolean     @default(true)
  notes        String?
  description  String?
  tags         String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([connectionId, node])
}

model DashboardLayout {
  id        String   @id @default(cuid())
  tenantId  String   @default("default") @map("tenant_id")
  userId    String   @default("default")
  name      String   @default("custom")
  widgets   Json   // array of widget descriptors
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, userId, name])
}

model Alert {
  id          String @id @default(cuid())
  tenantId    String @default("default") @map("tenant_id")
  fingerprint String

  // Alert info
  severity   String
  message    String
  source     String
  sourceType String @default("pve") @map("source_type")

  // Entity info
  entityType String? @map("entity_type")
  entityId   String? @map("entity_id")
  entityName String? @map("entity_name")

  // Metric info
  metric       String?
  currentValue Float?  @map("current_value")
  threshold    Float?

  // Status tracking
  status         String    @default("active")
  occurrences    Int       @default(1)
  firstSeenAt    DateTime  @default(now()) @map("first_seen_at")
  lastSeenAt     DateTime  @default(now()) @map("last_seen_at")
  acknowledgedAt DateTime? @map("acknowledged_at")
  acknowledgedBy String?   @map("acknowledged_by")
  resolvedAt     DateTime? @map("resolved_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, fingerprint])
  @@index([status])
  @@index([severity])
  @@index([source])
  @@index([lastSeenAt])
  @@index([status, severity, lastSeenAt])
  // Renamed from "alerts" → "frontend_alerts" during the SQLite → Postgres
  // consolidation. The backend orchestrator owns its own `alerts` table; this
  // rename keeps both alert systems on a single DB without colliding.
  @@map("frontend_alerts")
}

model AlertSilence {
  id            String    @id @default(cuid())
  tenantId      String    @default("default") @map("tenant_id")
  fingerprint   String
  silencedBy    String    @map("silenced_by")
  silencedAt    DateTime  @default(now()) @map("silenced_at")
  silencedUntil DateTime? @map("silenced_until")
  reason        String?

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([tenantId, fingerprint])
  @@index([silencedUntil])
  @@map("alert_silences")
}

model CustomImage {
  id                String   @id @default(cuid())
  tenantId          String   @default("default") @map("tenant_id")
  slug              String
  name              String
  vendor            String   @default("custom")
  version           String   @default("")
  arch              String   @default("amd64")
  format            String   @default("qcow2")
  sourceType        String   @default("url") @map("source_type") // "url" or "volume"
  downloadUrl       String?  @map("download_url")
  checksumUrl       String?  @map("checksum_url")
  volumeId          String?  @map("volume_id") // e.g. "local:import/golden-ubuntu.qcow2"
  defaultDiskSize   String   @default("20G") @map("default_disk_size")
  minMemory         Int      @default(512) @map("min_memory")
  recommendedMemory Int      @default(2048) @map("recommended_memory")
  minCores          Int      @default(1) @map("min_cores")
  recommendedCores  Int      @default(2) @map("recommended_cores")
  ostype            String   @default("l26")
  tags              String?
  // True when the image is part of the provider-managed catalogue, visible
  // to every tenant. Only the provider (tenant 'default') can flip this on.
  isShared          Boolean  @default(false) @map("is_shared")
  createdBy         String?  @map("created_by")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, slug])
  @@map("custom_images")
}

model Blueprint {
  id          String   @id @default(cuid())
  tenantId    String   @default("default") @map("tenant_id")
  name        String
  description String?
  imageSlug   String   @map("image_slug")
  hardware    Json   // { cores, sockets, memory, diskSize, scsihw, networkModel, networkBridge, vlanTag, ostype, agent, cpu }
  cloudInit   Json?   @map("cloud_init") // { ciuser, sshKeys, ipconfig0, nameserver, searchdomain }
  tags        String?
  isPublic    Boolean  @default(true) @map("is_public")
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("blueprints")
}

model Deployment {
  id            String    @id @default(cuid())
  tenantId      String    @default("default") @map("tenant_id")
  blueprintId   String?   @map("blueprint_id")
  blueprintName String?   @map("blueprint_name")
  connectionId  String    @map("connection_id")
  node          String
  vmid          Int
  vmName        String?   @map("vm_name")
  imageSlug     String?   @map("image_slug")
  config        Json?  // full deploy config for retry { storage, hardware, cloudInit }
  status        String    @default("pending") // pending|downloading|creating|configuring|starting|completed|failed
  currentStep   String?   @map("current_step")
  error         String?
  taskUpid      String?   @map("task_upid")
  startedAt     DateTime? @map("started_at")
  completedAt   DateTime? @map("completed_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([connectionId])
  @@map("deployments")
}

model MigrationJob {
  id       String @id @default(cuid())
  tenantId String @default("default") @map("tenant_id")

  // Source (ESXi)
  sourceConnectionId String  @map("source_connection_id")
  sourceVmId         String  @map("source_vm_id")
  sourceVmName       String? @map("source_vm_name")
  sourceHost         String? @map("source_host")

  // Target (Proxmox)
  targetConnectionId String @map("target_connection_id")
  targetNode         String @map("target_node")
  targetStorage      String @map("target_storage")
  targetVmid         Int?   @map("target_vmid")

  // Full config for retry
  config Json?

  // Status tracking
  status           String  @default("pending") // pending|preflight|creating_vm|transferring|configuring|completed|failed|cancelled
  currentStep      String? @map("current_step")
  progress         Int     @default(0)
  totalDisks       Int?    @map("total_disks")
  currentDisk      Int?    @map("current_disk")
  bytesTransferred BigInt? @map("bytes_transferred")
  totalBytes       BigInt? @map("total_bytes")
  transferSpeed    String? @map("transfer_speed")
  error            String?

  // Logs
  logs Json?  // array of log entries

  // Timing
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  createdBy String? @map("created_by")

  @@index([status])
  @@index([sourceConnectionId])
  @@index([targetConnectionId])
  @@map("migration_jobs")
}

// ============================================================================
// Models ported from lib/db/sqlite.ts during the SQLite → Postgres migration.
// Each section mirrors postgres-migration-inventory.md §1.1–1.6.
//
// Conventions:
//   - PascalCase model names; snake_case @@map for the table.
//   - camelCase Prisma fields; snake_case @map for the column.
//   - DateTime with @default(now()) replaces SQLite's TEXT + datetime('now').
//   - Boolean replaces SQLite's INTEGER 0/1.
//   - Json (JSONB on Postgres) replaces TEXT columns that hold JSON payloads.
//   - tenant_id stays a plain String when there is no FK in the source schema.
// ============================================================================

// ─────────────── §1.1 Identity / authn ───────────────

model User {
  id           String    @id
  tenantId     String    @default("default") @map("tenant_id")
  email        String    @unique
  password     String?
  name         String?
  avatar       String?
  role         String    @default("viewer")
  authProvider String    @default("credentials") @map("auth_provider")
  ldapDn       String?   @map("ldap_dn")
  oidcSub      String?   @map("oidc_sub")
  enabled      Boolean   @default(true)
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @map("created_at")
  updatedAt    DateTime  @map("updated_at")

  totpSecretEnc        String?   @map("totp_secret_enc")
  totpEnabled          Boolean   @default(false) @map("totp_enabled")
  totpEnrolledAt       DateTime?                @map("totp_enrolled_at")
  totpLastUsedStep     BigInt?                  @map("totp_last_used_step")
  totpRecoveryCodes    UserTotpRecoveryCode[]
  require2faEnrollment Boolean   @default(false) @map("require_2fa_enrollment")

  sessions            Session[]
  tenants             UserTenant[]
  rolesAssigned       RbacUserRole[]       @relation("RbacUserRoleUser")
  rolesGranted        RbacUserRole[]       @relation("RbacUserRoleGrantedBy")
  permissionsAssigned RbacUserPermission[] @relation("RbacUserPermissionUser")
  permissionsGranted  RbacUserPermission[] @relation("RbacUserPermissionGrantedBy")

  @@index([tenantId])
  @@map("users")
}

model UserTotpRecoveryCode {
  id          String    @id
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash    String    @map("code_hash")
  consumedAt  DateTime? @map("consumed_at")
  consumedIp  String?   @map("consumed_ip")
  createdAt   DateTime  @map("created_at")

  @@index([userId, consumedAt])
  @@map("user_totp_recovery_codes")
}

model Session {
  id        String   @id
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @map("created_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("sessions")
}

model AuditLog {
  id           String   @id
  tenantId     String   @default("default") @map("tenant_id")
  timestamp    DateTime
  userId       String?  @map("user_id")
  userEmail    String?  @map("user_email")
  action       String
  category     String
  resourceType String?  @map("resource_type")
  resourceId   String?  @map("resource_id")
  resourceName String?  @map("resource_name")
  // JSON payload describing the action's parameters / before-after snapshot.
  // Stored as TEXT in SQLite, promoted to JSONB on Postgres (locked decision §4).
  details      Json?
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  status       String   @default("success")
  errorMessage String?  @map("error_message")

  @@index([timestamp])
  @@index([userId])
  @@index([action])
  @@index([category])
  @@index([resourceType, resourceId])
  @@index([tenantId])
  @@map("audit_logs")
}

model LdapConfig {
  id               String   @id @default("default")
  tenantId         String   @default("default") @map("tenant_id")
  enabled          Boolean  @default(false)
  url              String
  bindDn           String?  @map("bind_dn")
  bindPasswordEnc  String?  @map("bind_password_enc")
  baseDn           String   @map("base_dn")
  userFilter       String   @default("(uid={{username}})") @map("user_filter")
  emailAttribute   String   @default("mail") @map("email_attribute")
  nameAttribute    String   @default("cn") @map("name_attribute")
  tlsInsecure      Boolean  @default(false) @map("tls_insecure")
  startTls         Boolean  @default(false) @map("start_tls")
  groupAttribute   String?  @default("memberOf") @map("group_attribute")
  // JSON object: { "<group_dn>": "<role_id>", ... }. Empty default '{}'.
  groupRoleMapping Json     @default("{}") @map("group_role_mapping")
  defaultRole      String?  @default("role_viewer") @map("default_role")
  requireGroup     Boolean  @default(false) @map("require_group")
  // JSON array of group DNs allowed to authenticate. Empty default '[]'.
  allowedGroups    Json     @default("[]") @map("allowed_groups")
  createdAt        DateTime @map("created_at")
  updatedAt        DateTime @map("updated_at")

  @@index([tenantId])
  @@map("ldap_config")
}

model OidcConfig {
  id               String   @id @default("default")
  tenantId         String   @default("default") @map("tenant_id")
  enabled          Boolean  @default(false)
  providerName     String   @default("SSO") @map("provider_name")
  issuerUrl        String   @default("") @map("issuer_url")
  clientId         String   @default("") @map("client_id")
  clientSecretEnc  String?  @map("client_secret_enc")
  scopes           String   @default("openid profile email")
  authorizationUrl String?  @map("authorization_url")
  tokenUrl         String?  @map("token_url")
  userinfoUrl      String?  @map("userinfo_url")
  claimEmail       String   @default("email") @map("claim_email")
  claimName        String   @default("name") @map("claim_name")
  claimGroups      String?  @default("groups") @map("claim_groups")
  autoProvision    Boolean  @default(true) @map("auto_provision")
  defaultRole      String   @default("viewer") @map("default_role")
  // Login-page behavior when SSO is enabled.
  // showLocalLogin=false hides the local/LDAP form from /login (only the SSO
  // button shows). The /access escape-hatch route ignores this flag.
  // forceSsoRedirect=true sends /login straight to the IdP.
  showLocalLogin   Boolean  @default(true)  @map("show_local_login")
  forceSsoRedirect Boolean  @default(false) @map("force_sso_redirect")
  // JSON object mapping IdP group claims to internal role names.
  groupRoleMapping Json     @default("{}") @map("group_role_mapping")
  createdAt        DateTime @map("created_at")
  updatedAt        DateTime @map("updated_at")

  @@index([tenantId])
  @@map("oidc_config")
}

// ─────────────── §1.2 Multi-tenancy ───────────────

model Tenant {
  id          String   @id
  slug        String   @unique
  name        String
  description String?
  enabled     Boolean  @default(true)
  // Free-form per-tenant settings (theme, feature flags, ...). JSONB.
  settings    Json?
  // v1.5 MSP: "iaas" | "msp" for non-default tenants; NULL only for the
  // 'default' (provider) tenant. Enforced by CHECK constraints in the
  // msp_alpha1_schema migration.
  operatingModel String? @map("operating_model")
  createdBy   String?  @map("created_by")
  createdAt   DateTime @map("created_at")
  updatedAt   DateTime @map("updated_at")

  members UserTenant[]
  vdcs    Vdc[]

  @@index([slug])
  @@map("tenants")
}

model UserTenant {
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  isDefault Boolean  @default(false) @map("is_default")
  joinedAt  DateTime @map("joined_at")

  @@id([userId, tenantId])
  @@index([userId])
  @@index([tenantId])
  @@map("user_tenants")
}

model Setting {
  key       String
  tenantId  String   @default("default") @map("tenant_id")
  value     Json     @db.JsonB
  updatedAt DateTime @default(now()) @map("updated_at")

  @@id([key, tenantId])
  @@unique([key, tenantId], map: "idx_settings_key_tenant")
  @@map("settings")
}

// ─────────────── §1.3 RBAC ───────────────

model RbacRole {
  id              String   @id
  name            String
  description     String?
  isSystem        Boolean  @default(false) @map("is_system")
  color           String?  @default("#6366f1")
  // Denylist of dashboard widget types hidden for users carrying this role.
  // Shape: { hidden: string[] }. Composed across roles as a union (any role
  // denying a widget hides it for the user).
  widgetOverrides Json?    @map("widget_overrides")
  // Default resource scope inherited by every assignment of this role whose
  // scopeType is "inherit". Shape: [{ scopeType, scopeTarget }] reusing the
  // assignment scope vocabulary (connection|node|vm|tag|pool). Null/empty =
  // global. Allowed on custom roles only — never on system roles, whose
  // super-admin/protected shortcuts bypass scope resolution entirely.
  defaultScopes   Json?    @map("default_scopes")
  // Tenant scoping. Null = global (system roles, visible to every tenant).
  // Non-null = custom role only visible to that tenant's admins.
  tenantId        String?  @map("tenant_id")
  createdAt       DateTime @map("created_at")
  updatedAt       DateTime @map("updated_at")

  permissions RbacRolePermission[]
  userRoles   RbacUserRole[]

  @@unique([tenantId, name])
  @@index([name])
  @@index([isSystem])
  @@index([tenantId])
  @@map("rbac_roles")
}

model RbacPermission {
  id          String   @id
  name        String   @unique
  category    String
  description String?
  isDangerous Boolean  @default(false) @map("is_dangerous")
  createdAt   DateTime @default(now()) @map("created_at")

  roles           RbacRolePermission[]
  userPermissions RbacUserPermission[]

  @@index([category])
  @@map("rbac_permissions")
}

model RbacRolePermission {
  roleId       String         @map("role_id")
  role         RbacRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String         @map("permission_id")
  permission   RbacPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("rbac_role_permissions")
}

model RbacUserRole {
  id          String    @id
  userId      String    @map("user_id")
  user        User      @relation("RbacUserRoleUser", fields: [userId], references: [id], onDelete: Cascade)
  roleId      String    @map("role_id")
  role        RbacRole  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  scopeType   String    @default("global") @map("scope_type")
  scopeTarget String?   @map("scope_target")
  tenantId    String    @default("default") @map("tenant_id")
  grantedById String?   @map("granted_by")
  grantedBy   User?     @relation("RbacUserRoleGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)
  grantedAt   DateTime  @map("granted_at")
  expiresAt   DateTime? @map("expires_at")

  @@index([userId])
  @@index([roleId])
  @@index([scopeType, scopeTarget])
  @@index([tenantId])
  @@map("rbac_user_roles")
}

model RbacUserPermission {
  id           String         @id
  userId       String         @map("user_id")
  user         User           @relation("RbacUserPermissionUser", fields: [userId], references: [id], onDelete: Cascade)
  permissionId String         @map("permission_id")
  permission   RbacPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  scopeType    String         @default("global") @map("scope_type")
  scopeTarget  String?        @map("scope_target")
  tenantId     String         @default("default") @map("tenant_id")
  grantedById  String?        @map("granted_by")
  grantedBy    User?          @relation("RbacUserPermissionGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)
  grantedAt    DateTime       @map("granted_at")
  expiresAt    DateTime?      @map("expires_at")

  @@index([userId])
  @@index([scopeType, scopeTarget])
  @@index([tenantId])
  @@map("rbac_user_permissions")
}

// ─────────────── §1.4 vDC ───────────────

model Vdc {
  id             String   @id
  tenantId       String   @map("tenant_id")
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  connectionId   String   @map("connection_id")
  // v1.5: a vDC may only reference a connection that is in the provider pool.
  // FK is to provider_connections (not directly to Connection); see migration.
  providerConnection ProviderConnection @relation(fields: [connectionId], references: [connectionId], onDelete: Restrict)
  name           String
  slug           String
  description    String?
  pvePoolName    String   @map("pve_pool_name")
  enabled        Boolean? @default(true)
  primaryStorage String?  @map("primary_storage")
  sdnZoneName    String?  @map("sdn_zone_name")
  createdBy      String?  @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @map("updated_at")

  nodes         VdcNode[]
  storages      VdcStorage[]
  quota         VdcQuota?
  usageCache    VdcUsageCache?
  sharedBridges VdcSharedBridge[]
  vnets         VdcVnet[]
  ipam          VdcIpamAllocation[]
  pbsNamespaces VdcPbsNamespace[]

  @@unique([tenantId, connectionId, slug])
  @@unique([connectionId, sdnZoneName], map: "idx_vdcs_sdn_zone_name")
  @@index([tenantId])
  @@index([connectionId])
  @@map("vdcs")
}

model VdcNode {
  id       String @id
  vdcId    String @map("vdc_id")
  vdc      Vdc    @relation(fields: [vdcId], references: [id], onDelete: Cascade)
  nodeName String @map("node_name")

  @@unique([vdcId, nodeName])
  @@index([vdcId])
  @@map("vdc_nodes")
}

// Legacy multi-row whitelist of allowed storages per vDC. Replaced for VM
// disks by Vdc.primaryStorage; today the table only holds PBS pseudo-storage
// bindings. Kept for parity per locked decision §3 (drop after a follow-up
// audit confirms zero callers).
model VdcStorage {
  id        String @id
  vdcId     String @map("vdc_id")
  vdc       Vdc    @relation(fields: [vdcId], references: [id], onDelete: Cascade)
  storageId String @map("storage_id")

  @@unique([vdcId, storageId])
  @@index([vdcId])
  @@map("vdc_storages")
}

model VdcQuota {
  id           String   @id
  vdcId        String   @unique @map("vdc_id")
  vdc          Vdc      @relation(fields: [vdcId], references: [id], onDelete: Cascade)
  maxVcpus     Int?     @map("max_vcpus")
  maxRamMb     Int?     @map("max_ram_mb")
  maxStorageMb Int?     @map("max_storage_mb")
  maxVms       Int?     @map("max_vms")
  maxSnapshots Int?     @map("max_snapshots")
  maxBackups   Int?     @map("max_backups")
  maxVnets     Int?     @map("max_vnets")
  updatedAt    DateTime @default(now()) @map("updated_at")

  @@map("vdc_quotas")
}

model VdcUsageCache {
  id            String    @id
  vdcId         String    @unique @map("vdc_id")
  vdc           Vdc       @relation(fields: [vdcId], references: [id], onDelete: Cascade)
  usedVcpus     Int       @default(0) @map("used_vcpus")
  usedRamMb     Int       @default(0) @map("used_ram_mb")
  usedStorageMb Int       @default(0) @map("used_storage_mb")
  usedVms       Int       @default(0) @map("used_vms")
  usedSnapshots Int       @default(0) @map("used_snapshots")
  usedBackups   Int       @default(0) @map("used_backups")
  lastSyncedAt  DateTime? @map("last_synced_at")

  @@map("vdc_usage_cache")
}

model VdcSharedBridge {
  id        String   @id
  vdcId     String   @map("vdc_id")
  vdc       Vdc      @relation(fields: [vdcId], references: [id], onDelete: Cascade)
  bridge    String
  label     String?
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([vdcId, bridge])
  @@index([vdcId])
  @@map("vdc_shared_bridges")
}

model VdcVnet {
  id          String   @id
  vdcId       String   @map("vdc_id")
  vdc         Vdc      @relation(fields: [vdcId], references: [id], onDelete: Cascade)
  pveName     String   @map("pve_name")
  displayName String?  @map("display_name")
  description String?
  vxlanTag    Int      @map("vxlan_tag")
  firewall    Boolean? @default(true)
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  subnet VdcSubnet?
  ipam   VdcIpamAllocation[]

  @@unique([vdcId, pveName])
  @@unique([vdcId, vxlanTag])
  @@unique([vdcId, displayName], map: "idx_vdc_vnets_display_name")
  @@index([vdcId])
  @@map("vdc_vnets")
}

model VdcSubnet {
  id          String   @id
  vnetId      String   @unique @map("vnet_id")
  vnet        VdcVnet  @relation(fields: [vnetId], references: [id], onDelete: Cascade)
  cidr        String
  gateway     String
  // Comma-separated list, optional.
  dnsServers  String?  @map("dns_servers")
  ipamEnabled Boolean  @default(true) @map("ipam_enabled")
  createdAt   DateTime @default(now()) @map("created_at")

  ipam VdcIpamAllocation[]

  @@index([vnetId])
  @@map("vdc_subnets")
}

model VdcIpamAllocation {
  id           String    @id
  vdcId        String    @map("vdc_id")
  vdc          Vdc       @relation(fields: [vdcId], references: [id], onDelete: Cascade)
  subnetId     String    @map("subnet_id")
  subnet       VdcSubnet @relation(fields: [subnetId], references: [id], onDelete: Cascade)
  vnetId       String    @map("vnet_id")
  vnet         VdcVnet   @relation(fields: [vnetId], references: [id], onDelete: Cascade)
  // Denormalised connection_id so the VM-delete hook can release in one query.
  connectionId String    @map("connection_id")
  ip           String
  // uint32 representation of the IP. SQLite stored it as INTEGER (any size);
  // Postgres `Int` (int4) overflows above 2.1 billion, so this column is
  // promoted to BigInt to safely hold values up to 4.3 billion (255.255.255.255).
  ipInt        BigInt    @map("ip_int")
  mac          String
  vmid         Int?
  hostname     String?
  createdAt    DateTime  @default(now()) @map("created_at")

  @@unique([subnetId, ip])
  @@unique([subnetId, mac])
  @@index([vdcId])
  @@index([subnetId])
  @@index([connectionId, vmid])
  @@map("vdc_ipam_allocations")
}

model VdcPbsNamespace {
  id              String   @id
  vdcId           String   @map("vdc_id")
  vdc             Vdc      @relation(fields: [vdcId], references: [id], onDelete: Cascade)
  pbsConnectionId String   @map("pbs_connection_id")
  datastore       String
  namespace       String
  mode            String   @default("auto")
  pbsTokenId      String?  @map("pbs_token_id")
  pbsTokenSecret  String?  @map("pbs_token_secret")
  createdAt       DateTime @default(now()) @map("created_at")

  pveStorages VdcPbsPveStorage[]

  @@unique([pbsConnectionId, datastore, namespace])
  @@index([vdcId])
  @@map("vdc_pbs_namespaces")
}

model VdcPbsPveStorage {
  id                String          @id
  vdcPbsNamespaceId String          @map("vdc_pbs_namespace_id")
  vdcPbsNamespace   VdcPbsNamespace @relation(fields: [vdcPbsNamespaceId], references: [id], onDelete: Cascade)
  pveConnectionId   String          @map("pve_connection_id")
  pveStorageName    String          @map("pve_storage_name")
  managed           Boolean         @default(true)
  createdAt         DateTime        @default(now()) @map("created_at")

  @@unique([pveConnectionId, pveStorageName])
  @@index([vdcPbsNamespaceId])
  @@map("vdc_pbs_pve_storages")
}

// ─────────────── §1.5 Alerts (legacy frontend system) ───────────────

model AlertRule {
  id          String   @id
  tenantId    String   @default("default") @map("tenant_id")
  name        String
  description String?
  enabled     Boolean  @default(true)
  metric      String
  operator    String
  threshold   Float
  duration    Int      @default(0)
  severity    String   @default("warning")
  scopeType   String   @default("all") @map("scope_type")
  scopeTarget String?  @map("scope_target")
  createdAt   DateTime @map("created_at")
  updatedAt   DateTime @map("updated_at")

  instances AlertInstance[]

  @@index([enabled])
  @@index([metric])
  @@index([tenantId])
  @@map("alert_rules")
}

model AlertInstance {
  id             String    @id
  tenantId       String    @default("default") @map("tenant_id")
  ruleId         String    @map("rule_id")
  rule           AlertRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  status         String    @default("active")
  entityType     String    @map("entity_type")
  entityId       String    @map("entity_id")
  entityName     String?   @map("entity_name")
  node           String?
  connectionId   String?   @map("connection_id")
  connectionName String?   @map("connection_name")
  metric         String
  currentValue   Float?    @map("current_value")
  threshold      Float
  severity       String
  message        String
  triggeredAt    DateTime  @map("triggered_at")
  resolvedAt     DateTime? @map("resolved_at")
  acknowledgedAt DateTime? @map("acknowledged_at")
  acknowledgedBy String?   @map("acknowledged_by")

  @@index([status])
  @@index([ruleId])
  @@index([triggeredAt])
  @@index([entityType, entityId])
  @@index([tenantId])
  @@map("alert_instances")
}

// Maps a backend orchestrator alert rule to the tenant that authored it. The
// orchestrator (Go) doesn't track tenant ownership on its rules, so we record
// it here at POST time and use it at GET time to scope both the rule list and
// the resulting alerts.
model AlertRuleOwner {
  ruleId    String   @id @map("rule_id")
  tenantId  String   @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("alert_rule_owners")
}

// ─────────────── §1.6 Misc / domain ───────────────

model Favorite {
  id           String   @id
  tenantId     String   @default("default") @map("tenant_id")
  userId       String   @map("user_id")
  vmKey        String   @map("vm_key")
  connectionId String   @map("connection_id")
  node         String
  vmType       String   @map("vm_type")
  vmid         String
  vmName       String?  @map("vm_name")
  createdAt    DateTime @map("created_at")

  @@unique([userId, vmKey])
  @@index([userId])
  @@index([vmKey])
  @@index([tenantId])
  @@map("favorites")
}

model HealthScoreHistory {
  id           String   @id
  tenantId     String   @default("default") @map("tenant_id")
  date         String   @unique
  score        Int
  cpuPct       Float?   @map("cpu_pct")
  ramPct       Float?   @map("ram_pct")
  storagePct   Float?   @map("storage_pct")
  // Free-form JSON detail snapshot.
  details      Json?
  connectionId String?  @map("connection_id")
  createdAt    DateTime @map("created_at")

  @@index([date])
  @@index([tenantId])
  @@map("health_score_history")
}

model SecurityPolicy {
  id                          String   @id @default("default")
  tenantId                    String   @default("default") @map("tenant_id")
  passwordMinLength           Int      @default(8) @map("password_min_length")
  passwordRequireUppercase    Boolean  @default(false) @map("password_require_uppercase")
  passwordRequireLowercase    Boolean  @default(false) @map("password_require_lowercase")
  passwordRequireNumbers      Boolean  @default(false) @map("password_require_numbers")
  passwordRequireSpecial      Boolean  @default(false) @map("password_require_special")
  sessionTimeoutMinutes       Int      @default(43200) @map("session_timeout_minutes")
  sessionMaxConcurrent        Int      @default(0) @map("session_max_concurrent")
  loginMaxFailedAttempts      Int      @default(0) @map("login_max_failed_attempts")
  loginLockoutDurationMinutes Int      @default(15) @map("login_lockout_duration_minutes")
  auditRetentionDays          Int      @default(90) @map("audit_retention_days")
  auditAutoCleanup            Boolean  @default(false) @map("audit_auto_cleanup")
  require2faForSuperAdmin     Boolean  @default(false) @map("require_2fa_for_super_admin")
  updatedAt                   DateTime @map("updated_at")
  updatedBy                   String?  @map("updated_by")

  @@index([tenantId])
  @@map("security_policies")
}

model ComplianceProfile {
  id           String   @id
  tenantId     String   @default("default") @map("tenant_id")
  name         String
  description  String?
  frameworkId  String?  @map("framework_id")
  isActive     Boolean  @default(false) @map("is_active")
  connectionId String?  @map("connection_id")
  createdBy    String?  @map("created_by")
  createdAt    DateTime @map("created_at")
  updatedAt    DateTime @map("updated_at")

  checks ComplianceProfileCheck[]

  @@index([isActive])
  @@index([connectionId])
  @@index([tenantId])
  @@map("compliance_profiles")
}

model ComplianceProfileCheck {
  id         String            @id
  tenantId   String            @default("default") @map("tenant_id")
  profileId  String            @map("profile_id")
  profile    ComplianceProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  checkId    String            @map("check_id")
  enabled    Boolean           @default(true)
  weight     Float             @default(1.0)
  controlRef String?           @map("control_ref")
  category   String?

  @@index([profileId])
  @@index([tenantId])
  @@map("compliance_profile_checks")
}

// Multi-DC Green-IT (Phase A) — provider-managed datacentre catalogue.
// idx_datacenters_default is a PARTIAL UNIQUE INDEX (`WHERE is_default = 1`)
// in SQLite. Prisma cannot express partial unique indexes today, so the
// constraint is recreated by a hand-written ALTER in the baseline migration.
// See postgres-migration-inventory.md step 1.3.
model Datacenter {
  id               String   @id
  tenantId         String   @default("default") @map("tenant_id")
  name             String
  locationLabel    String?  @map("location_label")
  country          String?
  latitude         Float?
  longitude        Float?
  pue              Float    @default(1.4)
  electricityPrice Float    @default(0.18) @map("electricity_price")
  currency         String   @default("EUR")
  co2Factor        Float    @default(0.052) @map("co2_factor")
  co2CountryPreset String?  @map("co2_country_preset")
  tdpPerCoreW      Float    @default(10) @map("tdp_per_core_w")
  wattsPerGbRam    Float    @default(0.375) @map("watts_per_gb_ram")
  overheadPerNodeW Float    @default(50) @map("overhead_per_node_w")
  comment          String?
  isDefault        Boolean  @default(false) @map("is_default")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @map("updated_at")

  connectionGreen ConnectionGreenConfig[]
  nodeGreen       NodeGreenConfig[]

  @@index([tenantId])
  @@map("datacenters")
}

model ConnectionGreenConfig {
  connectionId     String      @id @map("connection_id")
  connection       Connection  @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  datacenterId     String?     @map("datacenter_id")
  datacenter       Datacenter? @relation(fields: [datacenterId], references: [id], onDelete: SetNull)
  tdpPerCoreW      Float?      @map("tdp_per_core_w")
  wattsPerGbRam    Float?      @map("watts_per_gb_ram")
  overheadPerNodeW Float?      @map("overhead_per_node_w")
  updatedAt        DateTime    @default(now()) @map("updated_at")

  @@map("connection_green_config")
}

model NodeGreenConfig {
  connectionId     String      @map("connection_id")
  connection       Connection  @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  nodeName         String      @map("node_name")
  datacenterId     String?     @map("datacenter_id")
  datacenter       Datacenter? @relation(fields: [datacenterId], references: [id], onDelete: SetNull)
  tdpPerCoreW      Float?      @map("tdp_per_core_w")
  wattsPerGbRam    Float?      @map("watts_per_gb_ram")
  overheadPerNodeW Float?      @map("overhead_per_node_w")
  updatedAt        DateTime    @default(now()) @map("updated_at")

  @@id([connectionId, nodeName])
  @@map("node_green_config")
}

// TOFU host-key store for the frontend ssh2 path. Mirrors the backend
// orchestrator's /app/data/known_hosts store. Keyed by host (lowercased,
// without port — same host is assumed to present the same key on every
// SSH port we use). The first successful connection pins the key; every
// subsequent connection verifies it matches.
model SshHostKey {
  id          String   @id @default(cuid())
  host        String   @unique
  keyType     String   @map("key_type")
  keyData     Bytes    @map("key_data")
  firstSeenAt DateTime @default(now()) @map("first_seen_at")
  lastUsedAt  DateTime @default(now()) @updatedAt @map("last_used_at")

  @@map("ssh_host_keys")
}

// ============================================
// v1.5 MSP mode + multi-license (msp_alpha1_schema migration)
// ============================================

model ProviderConnection {
  // A connection is in the provider pool (vDC-sliceable) iff a row exists here.
  // App code keeps this in sync for PVE + tenant_id='default' connections only.
  connectionId String     @id @map("connection_id")
  connection   Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  vdcs         Vdc[]

  @@map("provider_connections")
}

model InstallIdentity {
  id          String    @id // install_uuid (UUIDv4)
  publicKey   String    @map("public_key")
  createdAt   DateTime  @default(now()) @map("created_at")
  lastResetAt DateTime? @map("last_reset_at")

  @@map("install_identities")
}

model License {
  id                 String   @id @default(cuid())
  licenseId          String   @unique @map("license_id")
  blob               String
  edition            String
  maxNodes           Int      @map("max_nodes")
  installableCount   Int?     @map("installable_count") // NULL = legacy unlimited
  clusterUuid        String?  @map("cluster_uuid")
  activatedAt        DateTime @default(now()) @map("activated_at")
  expiresAt          DateTime @map("expires_at")
  isPrimary          Boolean  @default(false) @map("is_primary")
  installFingerprint String   @map("install_fingerprint")
  features           Json?
  state              String   @default("active") // 'pending' | 'active' | 'expired'

  mappings LicenseMapping[]

  @@index([isPrimary])
  @@index([state])
  @@map("licenses")
  // Partial unique index "license_one_primary" added via raw SQL in the migration.
}

model LicenseMapping {
  licenseId    String @map("license_id")
  connectionId String @unique @map("connection_id")

  license    License    @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  connection Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@id([licenseId, connectionId])
  @@map("license_mappings")
}
