{
  "name": "proxcenter",
  "version": "1.4.5",
  "license": "Commercial",
  "private": true,
  "scripts": {
    "predev": "prisma generate && node scripts/ensure-internal-token.js",
    "dev": "concurrently \"next dev --turbopack\" \"node ws-proxy.js\"",
    "build": "next build",
    "prestart": "node scripts/ensure-internal-token.js",
    "start": "concurrently \"next start\" \"node ws-proxy.js\"",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\"",
    "build:icons": "tsx src/assets/iconify-icons/bundle-icons-css.mjs",
    "postinstall": "npm run build:icons",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:scripts": "vitest run --config vitest.scripts.config.ts",
    "clean": "rm -rf .next",
    "clear": "rm -rf node_modules .next"
  },
