# ProxCenter Docker Configuration
# Copy this file to .env and adjust values

# ========================================
# Required - Security Keys
# ========================================
# Generate with: openssl rand -base64 32
APP_SECRET=your-app-secret-change-me
NEXTAUTH_SECRET=your-nextauth-secret-change-me

# ========================================
# Required - Application URLs
# ========================================
# Public URL of your ProxCenter instance (used for redirects, callbacks)
NEXTAUTH_URL=https://proxcenter.example.com
APP_URL=https://proxcenter.example.com

# ========================================
# Database (Postgres)
# ========================================
# Postgres credentials for the bundled `postgres` compose service.
# In production these MUST be set to values you control. The defaults
# below are only suitable for local testing.
POSTGRES_USER=proxcenter
POSTGRES_PASSWORD=change-me-please
POSTGRES_DB=proxcenter

# Frontend connection string. The compose files build this same URL from
# the POSTGRES_* variables above and inject it as DATABASE_URL into the
# `proxcenter` service, so you usually don't need to set it explicitly.
# Override here if you point the frontend at an external Postgres.
# DATABASE_URL=postgresql://proxcenter:change-me-please@postgres:5432/proxcenter?schema=public

# ========================================
# Required for Enterprise edition - Orchestrator API key
# ========================================
# Shared secret used by the frontend to authenticate against the orchestrator
# REST API. Both services pick it up from this single variable
# (frontend: ORCHESTRATOR_API_KEY, orchestrator: PROXCENTER_API_API_KEY).
#
# Set it explicitly: with the post-migration startup order (frontend applies
# Prisma migrations before the orchestrator boots), the auto-generated key
# the orchestrator used to drop into a shared volume isn't readable in time.
# Generate with: openssl rand -hex 32
ORCHESTRATOR_API_KEY=your-orchestrator-api-key-change-me

# ========================================
# Optional - Version pinning
# ========================================
# VERSION=latest
